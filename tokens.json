{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "A cinematic, educational solar-system interface using deep-space surfaces, stellar gold, orbit cyan, and observatory-style glass panels.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.012,
          0.027,
          0.071
        ],
        "hex": "#030712"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.043,
          0.063,
          0.125
        ],
        "hex": "#0b1020"
      }
    },
    "tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.22,
          0.741,
          0.973
        ],
        "hex": "#38bdf8"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.984,
          0.749,
          0.141
        ],
        "hex": "#fbbf24"
      }
    },
    "planetBlue": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.376,
          0.647,
          0.98
        ],
        "hex": "#60a5fa"
      }
    },
    "mars": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.976,
          0.451,
          0.086
        ],
        "hex": "#f97316"
      }
    },
    "nebula": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.655,
          0.545,
          0.98
        ],
        "hex": "#a78bfa"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.973,
          0.98,
          0.988
        ],
        "hex": "#f8fafc"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.655,
          0.706,
          0.792
        ],
        "hex": "#a7b4ca"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.063,
          0.094,
          0.153
        ],
        "hex": "#101827"
      }
    },
    "surfaceRaised": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.086,
          0.141,
          0.227
        ],
        "hex": "#16243a"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.176,
          0.259,
          0.4
        ],
        "hex": "#2d4266"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 10,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 22,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 36,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.05,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": 0.04,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.55,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.03,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 450
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.72,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": 0.14,
          "unit": "em"
        }
      }
    }
  }
}
